{
  "name": "shehadeh-lawoffice-website",
  "version": "1.0.0",
  "description": "Static website for Shehadeh Law Office, a professional law firm based in Beit Jala, Palestine.",
  "scripts": {
    "scrape": "node scripts/scraper.js",
    "dev": "http-server src -p 8000 -c-1",
    "build": "echo 'Static site - no build required'",
    "start": "http-server src -p 8000",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug"
  },
  "keywords": [
    "law-office",
    "legal-service",
    "website",
    "static-site",
    "responsive",
    "seo"
  ],
  "author": "Fadi Shehadeh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:FadiSheh/shehadeh-law-office.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "http-server": "^14.1.1"
  }
}
